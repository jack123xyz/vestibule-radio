# Discord bot credentials
# Create a bot at https://discord.com/developers/applications
# Enable Message Content Intent in the Bot tab
DISCORD_BOT_TOKEN=your_bot_token_here
DISCORD_CHANNEL_ID=your_channel_or_thread_id_here

# Icecast / stream server (if using manual Icecast setup)
ICECAST_HOSTNAME=example.com
ICECAST_ADMIN_PASSWORD=changeme
ICECAST_SOURCE_PASSWORD=changeme
ICECAST_RELAY_PASSWORD=changeme

# Stream URL (used by the frontend)
STREAM_URL=http://localhost:8000/stream
METADATA_URL=http://localhost:8000/status-json.xsl
